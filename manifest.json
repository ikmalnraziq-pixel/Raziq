  "shortcuts": [
    {
      "name": "Ringkasan AI",
      "short_name": "Ringkasan",
      "description": "Buat ringkasan otomatis dari materi belajar",
      "url": "/Raziq/?shortcut=ringkasan&source=shortcut",
      "icons": [
        {
          "src": "icons/shortcut-ringkasan.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Kuis Interaktif",
      "short_name": "Kuis",
      "description": "Latihan soal kuis dari materi pelajaran",
      "url": "/Raziq/?shortcut=kuis&source=shortcut",
      "icons": [
        {
          "src": "icons/shortcut-kuis.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Flashcard",
      "short_name": "Flashcard",
      "description": "Hafal materi dengan flashcard interaktif",
      "url": "/Raziq/?shortcut=flashcard&source=shortcut",
      "icons": [
        {
          "src": "icons/shortcut-flashcard.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    },
    {
      "name": "Chat AI Tutor",
      "short_name": "Chat AI",
      "description": "Tanya apa saja ke AI tutor pintar",
      "url": "/Raziq/?shortcut=chat&source=shortcut",
      "icons": [
        {
          "src": "icons/shortcut-chat.png",
          "sizes": "96x96",
          "type": "image/png"
        }
      ]
    }
  ],
  "protocol_handlers": [
    {
      "protocol": "web+pelajarin",
      "url": "/Raziq/?protocol=%s"
    }
  ],
  "share_target": {
    "action": "/Raziq/share-target/",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "title",
      "text": "text",
      "url": "url",
      "files": [
        {
          "name": "file",
          "accept": [
            "application/pdf",
            "text/plain",
            "image/*"
          ]
        }
      ]
    }
  },
  "file_handlers": [
    {
      "action": "/Raziq/open-file/",
      "accept": {
        "application/pdf": [".pdf"],
        "text/plain": [".txt"]
      }
    }
  ],
  "edge_side_panel": {
    "preferred_width": 400
  },
  "handle_links": "preferred",
  "launch_handler": {
    "client_mode": [
      "navigate-existing",
      "auto"
    ]
  },
  "related_applications": [],
  "capture_links": "existing-client-navigate"
}
